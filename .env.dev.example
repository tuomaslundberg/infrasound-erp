# Dev environment overrides — copy to .env.dev and fill in values.
# Used by the dev Docker stack (make dev). DB name is fi_infrasound_dev (never prod data).
MYSQL_ROOT_PASSWORD=devpassword
MYSQL_DATABASE=fi_infrasound_dev
MYSQL_USER=erp_user
MYSQL_PASSWORD=devpassword
DB_HOST=db
ANTHROPIC_API_KEY=your_anthropic_api_key
WEBFLOW_WEBHOOK_SECRET=any_local_secret_for_testing
WEBFLOW_SIGNING_SECRET=any_local_secret_for_testing
# ETL: port exposed by the dev Docker stack on the host (default 3307)
ETL_DB_PORT=3307
# Spotify: used by setlist ETL to resolve track metadata
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
